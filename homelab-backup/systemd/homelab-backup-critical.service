[Unit]
Description=Homelab backup (critical tier, nightly)
Documentation=file:///opt/homelab-backup/docs/ARCHITECTURE.md
Wants=network-online.target
After=network-online.target docker.service

ConditionACPower=true

[Service]
Type=oneshot
ExecStart=/opt/homelab-backup/hosts/%H/backup-critical.sh
TimeoutStartSec=2h

User=root
Nice=19
IOSchedulingClass=idle
ProtectSystem=full
ProtectHome=read-only
NoNewPrivileges=true
PrivateTmp=true

Restart=no

[Install]
WantedBy=multi-user.target
